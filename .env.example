# ── Required ──────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Drive upload (optional) ────────────────────────────
# Path to a Google service-account JSON with Drive access
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# ID of the Drive folder to upload posts into
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# ── Email notification (optional) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Use a Gmail App Password if 2FA is enabled
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL_TO=recipient@example.com
NOTIFICATION_EMAIL_FROM=your_email@gmail.com
